  "publicApiSurface": [
    "GET /notes — List notes",
    "POST /notes — Create a note",
    "PUT /notes/:id — Update a note",
    "DELETE /notes/:id — Delete a note",
    "GET /notebooks — List notebooks",
    "POST /notebooks — Create a notebook",
    "GET /tags — List tags",
    "POST /tags/:id/notes — Tag a note",
    "GET /resources — List resources/attachments",
    "POST /resources — Upload a resource",
    "GET /search?query= — Full-text search",
